<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AgvDispatch.Mobile.ViewModels"
        x:Class="AgvDispatch.Mobile.Views.Dialogs.TaskDetailDialog"
        x:DataType="vm:TaskDetailDialogViewModel"
        Title="任务详情"
        Width="360"
        Height="600"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <Grid RowDefinitions="Auto,*,Auto" Background="White">
        <!-- 顶部标题栏 -->
        <Border Grid.Row="0"
                Background="{StaticResource PrimaryBrush}"
                Padding="16,12">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="任务详情"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="✕"
                        FontSize="20"
                        Foreground="White"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="32"
                        Height="32"
                        Padding="0"
                        Click="OnCloseClick"/>
            </Grid>
        </Border>

        <!-- 内容区域 -->
        <ScrollViewer Grid.Row="1"
                      Background="#FAFAFA"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <Grid Margin="16">
                <StackPanel Spacing="16" IsVisible="{Binding !IsLoading}">
                <!-- 任务ID卡片（始终显示） -->
                <Border Background="White"
                        CornerRadius="12"
                        Padding="16"
                        BoxShadow="0 2 8 0 #15000000">
                    <StackPanel Spacing="6">
                        <TextBlock Text="任务编号" FontSize="11" Foreground="#9E9E9E" FontWeight="Medium"/>
                        <TextBlock Text="{Binding Task.Id}"
                                   FontSize="12"
                                   Foreground="#424242"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- 基本信息卡片 -->
                <Border Background="White"
                        CornerRadius="12"
                        Padding="16"
                        BoxShadow="0 2 8 0 #15000000">
                    <StackPanel Spacing="16">
                        <TextBlock Text="基本信息" FontSize="14" FontWeight="SemiBold" Foreground="#212121"/>

                        <!-- 类型和状态 -->
                        <Grid ColumnDefinitions="*,*">
                            <StackPanel Grid.Column="0" Spacing="6" Margin="0,0,6,0">
                                <TextBlock Text="任务类型" FontSize="11" Foreground="#9E9E9E"/>
                                <Border Background="{StaticResource InfoBrush}"
                                        CornerRadius="8"
                                        Padding="10,6"
                                        HorizontalAlignment="Stretch">
                                    <TextBlock Text="{Binding Task.TaskType, Converter={StaticResource TaskJobTypeToTextConverter}}"
                                               FontSize="13"
                                               Foreground="White"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="6" Margin="6,0,0,0">
                                <TextBlock Text="任务状态" FontSize="11" Foreground="#9E9E9E"/>
                                <Border Background="{Binding Task.TaskStatus, Converter={StaticResource TaskJobStatusToBrushConverter}}"
                                        CornerRadius="8"
                                        Padding="10,6"
                                        HorizontalAlignment="Stretch">
                                    <TextBlock Text="{Binding Task.TaskStatus}"
                                               FontSize="13"
                                               Foreground="White"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- 优先级 -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="优先级" FontSize="11" Foreground="#9E9E9E"/>
                            <TextBlock Text="{Binding Task.Priority}"
                                       FontSize="15"
                                       Foreground="#212121"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <!-- 进度 -->
                        <StackPanel Spacing="6">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="完成进度" FontSize="11" Foreground="#9E9E9E"/>
                                <TextBlock Grid.Column="1" FontSize="13" Foreground="#424242" FontWeight="SemiBold">
                                    <Run Text="{Binding Task.ProgressPercentage, StringFormat='{}{0:F0}'}"/>
                                    <Run Text="%"/>
                                </TextBlock>
                            </Grid>
                            <ProgressBar Value="{Binding Task.ProgressPercentage}"
                                         Maximum="100"
                                         Height="10"
                                         CornerRadius="5"
                                         Foreground="{StaticResource SuccessBrush}"
                                         Background="#E8F5E9"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 路线信息卡片 -->
                <Border Background="White"
                        CornerRadius="12"
                        Padding="16"
                        BoxShadow="0 2 8 0 #15000000">
                    <StackPanel Spacing="16">
                        <TextBlock Text="路线信息" FontSize="14" FontWeight="SemiBold" Foreground="#212121"/>

                        <!-- 站点信息 -->
                        <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto">
                            <!-- 起点 -->
                            <TextBlock Grid.Column="0" Grid.Row="0"
                                       Text="起点"
                                       FontSize="11"
                                       Foreground="#9E9E9E"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <Border Grid.Column="1" Grid.Row="0"
                                    Background="#E3F2FD"
                                    CornerRadius="6"
                                    Padding="8,4"
                                    Margin="0,0,8,0">
                                <TextBlock Text="{Binding Task.StartStationCode}"
                                           FontSize="13"
                                           Foreground="#1976D2"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                            </Border>

                            <!-- 终点 -->
                            <TextBlock Grid.Column="2" Grid.Row="0"
                                       Text="终点"
                                       FontSize="11"
                                       Foreground="#9E9E9E"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <Border Grid.Column="3" Grid.Row="0"
                                    Background="#FCE4EC"
                                    CornerRadius="6"
                                    Padding="8,4">
                                <TextBlock Text="{Binding Task.EndStationCode}"
                                           FontSize="13"
                                           Foreground="#C2185B"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                            </Border>

                            <!-- 分配车辆 -->
                            <TextBlock Grid.Column="0" Grid.Row="1"
                                       Grid.ColumnSpan="1"
                                       Text="车辆"
                                       FontSize="11"
                                       Foreground="#9E9E9E"
                                       VerticalAlignment="Center"
                                       Margin="0,12,8,0"
                                       IsVisible="{Binding Task.AssignedAgvCode, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                            <Border Grid.Column="1" Grid.Row="1"
                                    Grid.ColumnSpan="3"
                                    Background="#F3E5F5"
                                    CornerRadius="6"
                                    Padding="8,4"
                                    Margin="0,12,0,0"
                                    IsVisible="{Binding Task.AssignedAgvCode, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <TextBlock Text="{Binding Task.AssignedAgvCode}"
                                           FontSize="13"
                                           Foreground="#7B1FA2"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 时间链卡片 -->
                <Border Background="White"
                        CornerRadius="12"
                        Padding="16"
                        BoxShadow="0 2 8 0 #15000000">
                    <StackPanel Spacing="12">
                        <TextBlock Text="时间链" FontSize="14" FontWeight="SemiBold" Foreground="#212121"/>

                        <StackPanel Spacing="10">
                            <!-- 创建时间 -->
                            <Grid ColumnDefinitions="Auto,8,*,Auto">
                                <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#4CAF50"/>
                                <Rectangle Grid.Column="1" Grid.ColumnSpan="3" Height="1" Fill="#E0E0E0" VerticalAlignment="Center" IsVisible="{Binding Task.AssignedAt, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                <StackPanel Grid.Column="2" Spacing="2" Margin="8,0,0,0">
                                    <TextBlock Text="创建时间" FontSize="10" Foreground="#9E9E9E"/>
                                    <TextBlock Text="{Binding Task.CreationDate, StringFormat='{}{0:MM-dd HH:mm:ss}'}"
                                               FontSize="12" Foreground="#424242" FontWeight="Medium"/>
                                </StackPanel>
                            </Grid>

                            <!-- 分配时间 -->
                            <Grid ColumnDefinitions="Auto,8,*,Auto" IsVisible="{Binding Task.AssignedAt, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#2196F3"/>
                                <Rectangle Grid.Column="1" Grid.ColumnSpan="3" Height="1" Fill="#E0E0E0" VerticalAlignment="Center" IsVisible="{Binding Task.StartedAt, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                <StackPanel Grid.Column="2" Spacing="2" Margin="8,0,0,0">
                                    <TextBlock Text="分配时间" FontSize="10" Foreground="#9E9E9E"/>
                                    <TextBlock Text="{Binding Task.AssignedAt, StringFormat='{}{0:MM-dd HH:mm:ss}'}"
                                               FontSize="12" Foreground="#424242" FontWeight="Medium"/>
                                </StackPanel>
                                <TextBlock Grid.Column="3"
                                           Text="{Binding WaitingTime}"
                                           FontSize="11"
                                           Foreground="#FF9800"
                                           FontWeight="SemiBold"/>
                            </Grid>

                            <!-- 开始时间 -->
                            <Grid ColumnDefinitions="Auto,8,*,Auto" IsVisible="{Binding Task.StartedAt, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#FF9800"/>
                                <Rectangle Grid.Column="1" Grid.ColumnSpan="3" Height="1" Fill="#E0E0E0" VerticalAlignment="Center" IsVisible="{Binding Task.CompletedAt, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                <StackPanel Grid.Column="2" Spacing="2" Margin="8,0,0,0">
                                    <TextBlock Text="开始时间" FontSize="10" Foreground="#9E9E9E"/>
                                    <TextBlock Text="{Binding Task.StartedAt, StringFormat='{}{0:MM-dd HH:mm:ss}'}"
                                               FontSize="12" Foreground="#424242" FontWeight="Medium"/>
                                </StackPanel>
                                <TextBlock Grid.Column="3"
                                           Text="{Binding ElapsedTime}"
                                           FontSize="11"
                                           Foreground="#4CAF50"
                                           FontWeight="SemiBold"
                                           IsVisible="{Binding Task.CompletedAt, Converter={x:Static ObjectConverters.IsNull}}"/>
                            </Grid>

                            <!-- 完成时间 -->
                            <Grid ColumnDefinitions="Auto,8,*,Auto" IsVisible="{Binding Task.CompletedAt, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#9C27B0"/>
                                <StackPanel Grid.Column="2" Spacing="2" Margin="8,0,0,0">
                                    <TextBlock Text="完成时间" FontSize="10" Foreground="#9E9E9E"/>
                                    <TextBlock Text="{Binding Task.CompletedAt, StringFormat='{}{0:MM-dd HH:mm:ss}'}"
                                               FontSize="12" Foreground="#424242" FontWeight="Medium"/>
                                </StackPanel>
                                <TextBlock Grid.Column="3"
                                           Text="{Binding TotalTime}"
                                           FontSize="11"
                                           Foreground="#9C27B0"
                                           FontWeight="SemiBold"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 错误信息 -->
                <Border Background="#FFEBEE"
                        CornerRadius="12"
                        Padding="16"
                        BoxShadow="0 2 8 0 #15000000"
                        IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="⚠ 错误信息"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ErrorBrush}"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   FontSize="12"
                                   Foreground="#C62828"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- 加载指示器 -->
            <Grid IsVisible="{Binding IsLoading}"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Center">
                <StackPanel Spacing="12" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True"
                                 Width="200"
                                 Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Text="加载中..."
                               FontSize="14"
                               Foreground="#757575"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
            </Grid>
        </ScrollViewer>

        <!-- 底部按钮 -->
        <Border Grid.Row="2"
                Background="#F5F5F5"
                BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0"
                Padding="16">
            <Grid ColumnDefinitions="*,Auto">
                <Button Grid.Column="0"
                        Command="{Binding CancelTaskCommand}"
                        IsVisible="{Binding CanCancel}"
                        IsEnabled="{Binding !IsCanceling}"
                        Background="{StaticResource ErrorBrush}"
                        Foreground="White"
                        Content="取消任务"
                        Height="40"
                        CornerRadius="8"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="1"
                        Content="关闭"
                        Height="40"
                        Width="100"
                        CornerRadius="8"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Background="{StaticResource PrimaryBrush}"
                        Foreground="White"
                        Click="OnCloseClick"/>
            </Grid>
        </Border>
    </Grid>
</Window>
