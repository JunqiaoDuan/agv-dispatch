<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AgvDispatch.Mobile.ViewModels"
             x:Class="AgvDispatch.Mobile.Views.Components.OperationsTabView"
             x:DataType="vm:TaskMonitorViewModel">

    <ScrollViewer Padding="16"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" VerticalAlignment="Center">
            <!-- 去上料按钮 -->
            <Button Command="{Binding OpenCallForLoadingDialogCommand}"
                    HorizontalAlignment="Stretch"
                    Height="90"
                    CornerRadius="12"
                    Background="{StaticResource SuccessBrush}"
                    Foreground="White">
                <StackPanel Spacing="6" HorizontalAlignment="Center">
                    <PathIcon Data="M9,16V10H5L12,3L19,10H15V16H9M5,20V18H19V20H5Z"
                              Width="36" Height="36"
                              Foreground="White"/>
                    <TextBlock Text="去上料"
                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="召唤小车到上料点"
                               FontSize="12"
                               Opacity="0.9"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- 去下料按钮 -->
            <Button Command="{Binding OpenSendToUnloadingDialogCommand}"
                    HorizontalAlignment="Stretch"
                    Height="90"
                    CornerRadius="12"
                    Background="{StaticResource InfoBrush}"
                    Foreground="White">
                <StackPanel Spacing="6" HorizontalAlignment="Center">
                    <PathIcon Data="M5,20H19V18H5M19,9H15V3H9V9H5L12,16L19,9Z"
                              Width="36" Height="36"
                              Foreground="White"/>
                    <TextBlock Text="去下料"
                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="指派小车到下料点"
                               FontSize="12"
                               Opacity="0.9"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- 让小车充电按钮 -->
            <Button Command="{Binding OpenSendToChargeDialogCommand}"
                    HorizontalAlignment="Stretch"
                    Height="90"
                    CornerRadius="12"
                    Background="{StaticResource PrimaryBrush}"
                    Foreground="White">
                <StackPanel Spacing="6" HorizontalAlignment="Center">
                    <PathIcon Data="M16.67,4H15V2H9V4H7.33A1.33,1.33 0 0,0 6,5.33V20.67C6,21.4 6.6,22 7.33,22H16.67A1.33,1.33 0 0,0 18,20.67V5.33C18,4.6 17.4,4 16.67,4Z"
                              Width="36" Height="36"
                              Foreground="White"/>
                    <TextBlock Text="让小车充电"
                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="将小车送往充电站"
                               FontSize="12"
                               Opacity="0.9"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </ScrollViewer>
</UserControl>
